      }
    },
    "settings.albumsync_conflict_multiple" : {
      "extractionState" : "manual",
      "comment" : "Same-name dialog when SEVERAL Proton albums share the name: linking would be ambiguous, only cancel is offered.",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Mehrere Proton-Alben tragen diesen Namen, eine eindeutige Verknüpfung ist nicht möglich. Benenne eines der Alben um und versuche es erneut." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Several Proton albums share this name, so linking would be ambiguous. Rename one of the albums and try again." } }
      }
    },
