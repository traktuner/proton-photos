{
  "sourceLanguage" : "en",
  "strings" : {
    "settings.photos_backup_unavailable" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Foto-Backup ist nicht verfügbar, weil der Duplikatschutz nicht initialisiert werden konnte." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Photos backup is unavailable because duplicate protection could not be initialized." } }
      }
    },
    "settings.photos_backup_explainer" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Sichert die Fotos und Videos deiner Mediathek Ende-zu-Ende-verschlüsselt in Proton Photos. Originale bleiben unverändert. Fotos, die bereits in Proton Photos sind – etwa von einem anderen Gerät oder aus der Proton Drive-App –, werden bei einer Prüfung erkannt und nie erneut hochgeladen. Beim Aktivieren wird Zugriff auf deine Fotos angefragt." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Backs up the photos and videos in your library to Proton Photos, end-to-end encrypted. Originals stay unchanged. Photos that are already in Proton Photos — for example from another device or the Proton Drive app — are recognized during a check and are never uploaded again. Enabling asks for access to your photos." } }
      }
    },
    "settings.photos_backup_enable" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Foto-Backup aktivieren…" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Enable Photos backup…" } }
      }
    },
    "settings.photos_backup_disable" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Foto-Backup deaktivieren" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Turn off Photos backup" } }
      }
    },
    "settings.photos_backup_denied" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Zugriff auf Fotos ist nicht erlaubt. Du kannst ihn in den Einstellungen erlauben." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Photos access is not allowed. You can grant it in Settings." } }
      }
    },
    "settings.albumsync_add_albums" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Alben auswählen" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Choose albums" } }
      }
    },
    "settings.albumsync_sync_all" : {
      "extractionState" : "manual",
      "comment" : "Syncs every selected album (sequentially).",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Jetzt synchronisieren" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Sync now" } }
      }
    },
    "settings.albumsync_remove" : {
      "extractionState" : "manual",
      "comment" : "Swipe/VoiceOver label of the per-row remove control. Removal only stops syncing - nothing is deleted on Proton.",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Aus Sync entfernen" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Remove from sync" } }
      }
    },
    "settings.albumsync_decide" : {
      "extractionState" : "manual",
      "comment" : "Row button re-opening the same-name conflict dialog.",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Entscheiden…" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Decide…" } }
      }
    },
    "settings.albumsync_row_attention %lld" : {
      "extractionState" : "manual",
      "comment" : "Per-row count of photos the last run could not back up or attach.",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "%lld benötigen Aufmerksamkeit" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "%lld need attention" } }
      }
    },
