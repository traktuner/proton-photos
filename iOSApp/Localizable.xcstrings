      }
    },
    "settings.albumsync_conflict_message %@" : {
      "extractionState" : "manual",
      "comment" : "Body of the same-name dialog; %@ is the local album title. The user decides, the app never attaches by name match on its own.",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Füge die Fotos von „%@“ dem bestehenden Proton-Album hinzu, oder brich ab und benenne eines der Alben um." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Add the photos of “%@” to the existing Proton album, or cancel and rename one of the albums." } }
      }
    },
    "settings.albumsync_row" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Alben mit Proton synchronisieren" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Sync albums to Proton" } }
      }
    },
    "settings.albumsync_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Album-Synchronisierung" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Album Sync" } }
      }
    },
    "settings.albumsync_explainer" : {
      "extractionState" : "manual",
      "comment" : "Footer of the album list. Honest wording: already-backed-up photos are linked, never re-uploaded.",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Synchronisiere ein Apple-Fotos-Album in ein Proton Photos-Album. Bereits gesicherte Fotos werden nur verknüpft, nie erneut hochgeladen." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Sync an Apple Photos album into a Proton Photos album. Photos already backed up are only linked, never uploaded again." } }
      }
    },
    "settings.albumsync_unavailable" : {
      "extractionState" : "manual",
      "comment" : "Shown when the album-sync mapping database or duplicate protection could not be opened.",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Album-Synchronisierung ist nicht verfügbar, weil die lokale Datenbank nicht geöffnet werden konnte." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Album sync is unavailable because its local database could not be opened." } }
      }
    },
    "settings.albumsync_stop" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Stoppen" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Stop" } }
