    "settings.photos_backup_background_note" : {
      "extractionState" : "manual",
      "comment" : "Honest background wording: uploads continue while the app is open and in system-granted charging windows; iOS may pause them otherwise.",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Die Sicherung läuft, während die App geöffnet ist, und in vom System gewährten Zeitfenstern (meist beim Laden). iOS kann sie dazwischen pausieren – sie wird automatisch fortgesetzt." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Backup runs while the app is open and in system-granted windows (usually while charging). iOS may pause it in between - it resumes automatically." } }
