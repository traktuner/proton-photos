    "settings.offline_library_help": {
      "extractionState": "manual",
      "comment": "Help text under the Offline Library toggle.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Preview thumbnails are always loaded locally encrypted so the grid works. This switch is reserved for larger offline derivatives in the future."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vorschaubilder werden immer lokal verschlüsselt geladen, damit das Raster funktioniert. Dieser Schalter ist für zukünftige größere Offline-Derivate reserviert."
          }
        }
      }
    },
