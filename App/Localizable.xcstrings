    "login.tagline": {
      "extractionState": "manual",
      "comment": "Product tagline under the app name on the login screen.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your photos, end-to-end encrypted."
          }
