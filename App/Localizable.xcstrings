    "settings.cache_deletion_help": {
      "extractionState": "manual",
      "comment": "Explains cache-retention behavior.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deletes everything cached on disk - thumbnails, previews, and originals - for the current account, as if you just signed in. Thumbnails re-crawl automatically."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Löscht alles lokal Gecachte - Thumbnails, Vorschauen und Originale - für den aktuellen Account, wie frisch eingeloggt. Thumbnails werden automatisch neu geladen."
          }
        }
      }
    },
