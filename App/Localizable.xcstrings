    "login.sign_in_button": {
      "extractionState": "manual",
      "comment": "Primary sign-in button.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign in with Proton"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit Proton anmelden"
