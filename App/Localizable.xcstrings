{
  "sourceLanguage": "en",
  "strings": {
    "settings.photos_backup_section": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Photos Library" } },
        "de": { "stringUnit": { "state": "translated", "value": "Foto-Mediathek" } }
      }
    },
    "settings.photos_backup_explainer": {
      "extractionState": "manual",
      "comment": "Shown BEFORE the system permission prompt - states plainly what enabling will do.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Backs up your photos and videos to Proton Photos, encrypted. Your originals stay untouched, and nothing is ever deleted from your library. Photos that are already in Proton Photos get recognized and are never uploaded again. Turning this on needs access to your photos." } },
        "de": { "stringUnit": { "state": "translated", "value": "Sichert deine Fotos und Videos verschlüsselt in Proton Photos. Deine Originale bleiben unverändert, und es wird nie etwas aus deiner Mediathek gelöscht. Fotos, die schon in Proton Photos liegen, werden erkannt und nicht noch mal hochgeladen. Zum Aktivieren braucht die App Zugriff auf deine Fotos." } }
      }
    },
    "settings.photos_backup_enable": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Enable Photos backup…" } },
        "de": { "stringUnit": { "state": "translated", "value": "Foto-Backup aktivieren…" } }
      }
    },
    "settings.photos_backup_disable": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Turn off Photos backup" } },
        "de": { "stringUnit": { "state": "translated", "value": "Foto-Backup deaktivieren" } }
      }
    },
    "settings.photos_backup_denied": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Photos access isn’t allowed. You can grant it in System Settings under Privacy & Security › Photos." } },
        "de": { "stringUnit": { "state": "translated", "value": "Zugriff auf Fotos ist nicht erlaubt. Du kannst ihn in den Systemeinstellungen unter Datenschutz & Sicherheit › Fotos erlauben." } }
      }
    },
    "settings.photos_backup_limited": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Only the photos you selected are backed up." } },
        "de": { "stringUnit": { "state": "translated", "value": "Nur die von dir ausgewählten Fotos werden gesichert." } }
      }
    },
    "settings.backup_uploads_section": {
      "extractionState": "manual",
      "comment": "Backup tab section for the manual upload queue's pre-upload check.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Uploads" } },
        "de": { "stringUnit": { "state": "translated", "value": "Uploads" } }
      }
    },
    "settings.backup_tab": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Backup" } },
        "de": { "stringUnit": { "state": "translated", "value": "Backup" } }
      }
    },
    "settings.backup_folders_section": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Folders" } },
        "de": { "stringUnit": { "state": "translated", "value": "Ordner" } }
      }
    },
    "settings.backup_no_folders": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "No folders selected yet. Added folders are backed up to Proton Photos, encrypted." } },
        "de": { "stringUnit": { "state": "translated", "value": "Noch keine Ordner ausgewählt. Hinzugefügte Ordner werden verschlüsselt in Proton Photos gesichert." } }
      }
    },
    "settings.backup_add_folder": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Add Folder…" } },
        "de": { "stringUnit": { "state": "translated", "value": "Ordner hinzufügen…" } }
      }
    },
    "settings.backup_add_folder_prompt": {
      "extractionState": "manual",
      "comment": "Confirm button of the folder picker panel.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Back Up Folder" } },
        "de": { "stringUnit": { "state": "translated", "value": "Ordner sichern" } }
      }
    },
    "settings.backup_folder_stale": {
      "extractionState": "manual",
      "comment": "Shown under a folder whose sandbox bookmark no longer resolves.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Access must be renewed - please add this folder again" } },
        "de": { "stringUnit": { "state": "translated", "value": "Zugriff muss erneuert werden - bitte Ordner erneut hinzufügen" } }
      }
    },
    "settings.backup_status_section": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Backup status" } },
        "de": { "stringUnit": { "state": "translated", "value": "Backup-Status" } }
      }
    },
    "settings.backup_unavailable": {
      "extractionState": "manual",
      "comment": "Shown when the duplicate-protection store could not be opened; backup is disabled rather than risking double uploads.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Backup is unavailable because duplicate protection could not be initialized." } },
        "de": { "stringUnit": { "state": "translated", "value": "Backup ist nicht verfügbar, weil der Duplikatschutz nicht initialisiert werden konnte." } }
      }
    },
    "settings.backup_sync_now": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Back up now" } },
        "de": { "stringUnit": { "state": "translated", "value": "Jetzt sichern" } }
      }
    },
    "settings.albumsync_add_albums": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Choose albums…" } },
        "de": { "stringUnit": { "state": "translated", "value": "Alben auswählen…" } }
      }
    },
    "settings.albumsync_sync_all": {
      "extractionState": "manual",
      "comment": "Syncs every selected album (sequentially).",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Sync now" } },
        "de": { "stringUnit": { "state": "translated", "value": "Jetzt synchronisieren" } }
      }
    },
    "settings.albumsync_remove": {
      "extractionState": "manual",
      "comment": "Tooltip/VoiceOver label of the per-row remove control. Removal only stops syncing - nothing is deleted on Proton.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Remove from sync" } },
        "de": { "stringUnit": { "state": "translated", "value": "Aus Sync entfernen" } }
      }
    },
    "settings.albumsync_decide": {
      "extractionState": "manual",
      "comment": "Row button re-opening the same-name conflict dialog.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Decide…" } },
        "de": { "stringUnit": { "state": "translated", "value": "Entscheiden…" } }
      }
    },
    "settings.albumsync_row_attention %lld": {
      "extractionState": "manual",
      "comment": "Per-row count of photos the last run could not back up or attach.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "%lld need attention" } },
        "de": { "stringUnit": { "state": "translated", "value": "%lld benötigen Aufmerksamkeit" } }
      }
    },
    "settings.albumsync_picker_title": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Choose albums to sync" } },
        "de": { "stringUnit": { "state": "translated", "value": "Alben für Sync auswählen" } }
      }
    },
    "settings.albumsync_picker_search": {
      "extractionState": "manual",
      "comment": "Placeholder of the picker's search field.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Search albums" } },
        "de": { "stringUnit": { "state": "translated", "value": "Alben durchsuchen" } }
      }
    },
    "settings.albumsync_picker_empty": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "No albums match." } },
        "de": { "stringUnit": { "state": "translated", "value": "Keine passenden Alben." } }
      }
    },
    "settings.albumsync_picker_selected %lld": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "variations": {
            "plural": {
              "one": { "stringUnit": { "state": "translated", "value": "%lld album selected" } },
              "other": { "stringUnit": { "state": "translated", "value": "%lld albums selected" } }
            }
          }
        },
        "de": {
          "variations": {
            "plural": {
              "one": { "stringUnit": { "state": "translated", "value": "%lld Album ausgewählt" } },
              "other": { "stringUnit": { "state": "translated", "value": "%lld Alben ausgewählt" } }
            }
          }
        }
      }
    },
    "settings.albumsync_picker_apply": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Apply" } },
        "de": { "stringUnit": { "state": "translated", "value": "Übernehmen" } }
      }
    },
    "settings.albumsync_conflict_message %@": {
      "extractionState": "manual",
      "comment": "Body of the same-name dialog; %@ is the local album title. The user decides, the app never attaches by name match on its own.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Add the photos of “%@” to the existing Proton album, or cancel and rename one of the albums." } },
        "de": { "stringUnit": { "state": "translated", "value": "Füge die Fotos von „%@“ dem bestehenden Proton-Album hinzu, oder brich ab und benenne eines der Alben um." } }
      }
    },
    "settings.albumsync_section": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Photos Albums" } },
        "de": { "stringUnit": { "state": "translated", "value": "Foto-Alben" } }
      }
    },
    "settings.albumsync_explainer": {
      "extractionState": "manual",
      "comment": "Shown before the local album list is loaded. Loading requires photo access, which is only requested on the button press.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Sync an Apple Photos album into a Proton Photos album. Photos already backed up are only linked, never uploaded again." } },
        "de": { "stringUnit": { "state": "translated", "value": "Synchronisiere ein Apple-Fotos-Album in ein Proton Photos-Album. Bereits gesicherte Fotos werden nur verknüpft, nie erneut hochgeladen." } }
      }
    },
    "settings.albumsync_photo_count %lld": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "variations": {
            "plural": {
              "one": { "stringUnit": { "state": "translated", "value": "%lld photo" } },
              "other": { "stringUnit": { "state": "translated", "value": "%lld photos" } }
            }
          }
        },
        "de": {
          "variations": {
            "plural": {
              "one": { "stringUnit": { "state": "translated", "value": "%lld Foto" } },
              "other": { "stringUnit": { "state": "translated", "value": "%lld Fotos" } }
            }
          }
        }
      }
    },
    "settings.albumsync_conflict_title": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "A Proton album with this name already exists" } },
        "de": { "stringUnit": { "state": "translated", "value": "Ein Proton-Album mit diesem Namen existiert bereits" } }
      }
    },
    "settings.albumsync_conflict_multiple": {
      "extractionState": "manual",
      "comment": "Same-name dialog when SEVERAL Proton albums share the name: attaching would be ambiguous, so only cancel is offered.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Several Proton albums share this name, so linking would be ambiguous. Rename one of the albums and try again." } },
        "de": { "stringUnit": { "state": "translated", "value": "Mehrere Proton-Alben tragen diesen Namen, eine eindeutige Verknüpfung ist nicht möglich. Benenne eines der Alben um und versuche es erneut." } }
      }
    },
    "settings.albumsync_use_existing": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Use existing album" } },
        "de": { "stringUnit": { "state": "translated", "value": "Bestehendes Album verwenden" } }
      }
    },
    "settings.backup_stop": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Stop" } },
        "de": { "stringUnit": { "state": "translated", "value": "Stoppen" } }
      }
    },
    "settings.backup_backed_up %lld %lld": {
      "extractionState": "manual",
      "comment": "First %lld: proven backed-up count. Second %lld: total. The ONLY number presented as backed up.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "%lld of %lld backed up" } },
        "de": { "stringUnit": { "state": "translated", "value": "%lld von %lld gesichert" } }
      }
    },
    "settings.backup_row_skipped_deleted %lld": {
      "extractionState": "manual",
      "comment": "Items whose identical remote copy is trashed/deleted - deliberately NOT re-uploaded.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Skipped (deleted in Proton Photos): %lld" } },
        "de": { "stringUnit": { "state": "translated", "value": "Übersprungen (in Proton Photos gelöscht): %lld" } }
      }
    },
    "settings.backup_row_source_missing %lld": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "No longer on this Mac: %lld" } },
        "de": { "stringUnit": { "state": "translated", "value": "Nicht mehr auf diesem Mac: %lld" } }
      }
    },
    "settings.backup_row_blocked %lld": {
      "extractionState": "manual",
      "comment": "Items parked behind a remote upload draft; re-checked automatically.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Will be re-checked later: %lld" } },
        "de": { "stringUnit": { "state": "translated", "value": "Werden später erneut geprüft: %lld" } }
      }
    },
    "settings.backup_row_failed %lld": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Need attention: %lld" } },
        "de": { "stringUnit": { "state": "translated", "value": "Benötigen Aufmerksamkeit: %lld" } }
      }
    },
    "action.cancel": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancel"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Abbrechen"
          }
        }
      }
    },
    "action.retry": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Retry"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erneut versuchen"
          }
        }
      }
    },
    "action.sign_out": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign out"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Abmelden"
          }
        }
      }
    },
    "action.delete": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Löschen"
          }
        }
      }
    },
    "action.ok": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "OK"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "OK"
          }
        }
      }
    },
    "alert.trash_action_failed_title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Action Failed"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktion fehlgeschlagen"
          }
        }
      }
    },
    "alert.trash_failed_message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The photos couldn't be moved to Recently Deleted. They are still in your library."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Fotos konnten nicht in „Zuletzt gelöscht“ verschoben werden. Sie sind weiterhin in deiner Mediathek."
          }
        }
      }
    },
    "alert.restore_failed_message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The photos couldn't be restored. They are still in Recently Deleted."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Fotos konnten nicht wiederhergestellt werden. Sie sind weiterhin in „Zuletzt gelöscht“."
          }
        }
      }
    },
    "trash.empty_button": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Empty Recently Deleted"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Papierkorb leeren"
          }
        }
      }
    },
    "trash.empty_title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Empty Recently Deleted?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Papierkorb endgültig leeren?"
          }
        }
      }
    },
    "trash.empty_message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All photos and videos in Recently Deleted will be permanently deleted. This can’t be undone."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle Fotos und Videos in „Zuletzt gelöscht“ werden endgültig gelöscht. Das kann nicht rückgängig gemacht werden."
          }
        }
      }
    },
    "trash.empty_confirm": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete Permanently"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Endgültig löschen"
          }
        }
      }
    },
    "trash.empty_failed_message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Recently Deleted couldn’t be emptied. The items are still there."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„Zuletzt gelöscht“ konnte nicht geleert werden. Die Objekte sind weiterhin dort."
          }
        }
      }
    },
    "trash.empty_failed_title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t Empty Recently Deleted"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Papierkorb konnte nicht geleert werden"
          }
        }
      }
    },
    "map.empty_title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No places yet"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch keine Orte"
          }
        }
      }
    },
    "map.empty_message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Photos with location data appear here. If you just signed in, this can take a moment while your library is scanned."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fotos mit Standortdaten erscheinen hier. Direkt nach der Anmeldung kann dies einen Moment dauern, während deine Mediathek durchsucht wird."
          }
        }
      }
    },
    "map.no_places_found_message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Scan complete — no location data was found in your photos."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Suche ist abgeschlossen – deine Fotos enthalten keine Standortdaten."
          }
        }
      }
    },
    "map.scan_failed_title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Scan failed"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Suche fehlgeschlagen"
          }
        }
      }
    },
    "map.scan_failed_message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Location data couldn't be loaded. Please try again later."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Standortdaten konnten nicht geladen werden. Bitte später erneut versuchen."
          }
        }
      }
    },
    "map.scanning_title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Scanning for places…"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Suche nach Orten …"
          }
        }
      }
    },
    "map.scanning_message %lld %lld": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld of %2$lld photos scanned. Places appear as they are found."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld von %2$lld Fotos durchsucht. Orte erscheinen, sobald sie gefunden werden."
          }
        }
      }
    },
    "action.refresh": {
      "extractionState": "manual",
