    "login.sign_in_button": {
      "extractionState": "manual",
      "comment": "Primary sign-in button.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign in with Proton"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit Proton anmelden"
          }
        }
      }
    },
    "login.help_text": {
      "extractionState": "manual",
      "comment": "Explains the browser-based sign-in flow.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Opens your browser to sign in securely. No password is ever entered in this app."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffnet Ihren Browser zur sicheren Anmeldung. In dieser App wird niemals ein Passwort eingegeben."
          }
        }
      }
    },
    "login.footer": {
      "extractionState": "manual",
      "comment": "Login footer. “Proton AG” is a brand name.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Proton AG · Encrypted by default"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Proton AG · Standardmäßig verschlüsselt"
          }
        }
      }
    },
    "auth.requesting_signin_link": {
