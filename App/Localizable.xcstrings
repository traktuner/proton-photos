    "settings.cache_deletion_help": {
      "extractionState": "manual",
      "comment": "Explains cache-retention behavior.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The encrypted thumbnail/preview cache is kept when the offline library is turned off and is only removed with this button."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der verschlüsselte Thumbnail-/Vorschau-Cache bleibt beim Deaktivieren der Offline-Mediathek erhalten und wird nur über diese Schaltfläche gelöscht."
          }
        }
      }
    },
