    "settings.cache_limit_help": {
      "extractionState": "manual",
      "comment": "Explains the originals cache limit + LRU eviction.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Full-resolution originals you open are kept locally. When limited, the least-recently-opened are removed once the cap is reached."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Geöffnete Originale in voller Auflösung werden lokal behalten. Bei „Begrenzt“ werden die am längsten nicht geöffneten entfernt, sobald das Limit erreicht ist."
          }
        }
      }
    },
