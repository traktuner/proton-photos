        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Video-Informationen konnten nicht geladen werden."
          }
        }
      }
    },
    "error.video.unsupported_codec": {
      "extractionState": "manual",
      "comment": "AVFoundation can’t decode the codec.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This video format isn’t supported."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Videoformat wird nicht unterstützt."
          }
        }
      }
    },
    "error.video.stream_unavailable": {
      "extractionState": "manual",
      "comment": "Backend exposes no stream URL.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No stream is available for this video."
