{
  "sourceLanguage": "en",
  "strings": {
    "backup.detail_already_backed_up %lld": {
      "extractionState": "manual",
      "comment": "Completed-state detail: how many items were already safe and skipped without uploading.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Already backed up: %lld" } },
        "de": { "stringUnit": { "state": "translated", "value": "Bereits gesichert: %lld" } }
      }
    },
    "backup.detail_attention %lld": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "%lld files need attention" } },
        "de": { "stringUnit": { "state": "translated", "value": "%lld Dateien benötigen Aufmerksamkeit" } }
      }
    },
    "backup.detail_backed_up %lld %lld": {
      "extractionState": "manual",
      "comment": "Uploading-state detail. First %lld: proven backed-up count, second: total considered.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "%lld of %lld backed up" } },
        "de": { "stringUnit": { "state": "translated", "value": "%lld von %lld gesichert" } }
      }
    },
    "backup.detail_checked %lld %lld": {
      "extractionState": "manual",
      "comment": "Checking-state detail. Deliberately 'checked', never 'uploaded' or 'hashed'.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "%lld of %lld checked" } },
        "de": { "stringUnit": { "state": "translated", "value": "%lld von %lld geprüft" } }
      }
    },
    "backup.detail_waiting %lld": {
      "extractionState": "manual",
      "comment": "Waiting-state detail: outstanding items that continue on the next run.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "%lld files will continue on the next run" } },
        "de": { "stringUnit": { "state": "translated", "value": "%lld Dateien werden beim nächsten Durchlauf fortgesetzt" } }
      }
    },
    "backup.phase_attention": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Some files need attention" } },
        "de": { "stringUnit": { "state": "translated", "value": "Einige Dateien benötigen Aufmerksamkeit" } }
      }
    },
    "backup.phase_checking": {
      "extractionState": "manual",
      "comment": "Headline while proving items are already backed up (identity + duplicate check). NEVER worded as uploading or hashing - a user whose library already lives in Proton (e.g. synced via the official Drive app) must read this as verification, not as a re-upload.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Checking what’s already backed up" } },
        "de": { "stringUnit": { "state": "translated", "value": "Es wird geprüft, was bereits gesichert ist" } }
      }
    },
    "backup.phase_completed": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "All files backed up" } },
        "de": { "stringUnit": { "state": "translated", "value": "Alle Dateien gesichert" } }
      }
    },
    "backup.phase_idle": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Ready" } },
        "de": { "stringUnit": { "state": "translated", "value": "Bereit" } }
      }
    },
    "backup.phase_paused": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Paused" } },
        "de": { "stringUnit": { "state": "translated", "value": "Pausiert" } }
      }
    },
    "backup.phase_scanning": {
      "extractionState": "manual",
      "comment": "Headline while enumerating folders/assets. Totals are unknown - UI shows an indeterminate spinner.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Looking for files…" } },
        "de": { "stringUnit": { "state": "translated", "value": "Dateien werden gesucht…" } }
      }
    },
    "backup.phase_uploading": {
      "extractionState": "manual",
      "comment": "Headline ONLY while bytes are actually uploading.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Backing up" } },
        "de": { "stringUnit": { "state": "translated", "value": "Wird gesichert" } }
      }
    },
    "backup.phase_waiting": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Waiting to continue" } },
        "de": { "stringUnit": { "state": "translated", "value": "Wartet auf Fortsetzung" } }
      }
    },
    "backup.error_source_missing": {
      "extractionState": "manual",
      "comment": "Backup queue row error: the local source file disappeared before it could be backed up.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The file no longer exists on this device"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Datei ist auf diesem Gerät nicht mehr vorhanden"
          }
        }
      }
    },
    "backup.state_skipped_remote_deletion": {
      "extractionState": "manual",
      "comment": "Backup queue row note: the identical photo is in the Proton trash or was deleted remotely, so it is deliberately not re-uploaded and not counted as backed up.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Skipped: deleted in Proton Photos"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Übersprungen: in Proton Photos gelöscht"
          }
        }
      }
    },
    "albumsync.phase_idle": {
      "extractionState": "manual",
      "comment": "Album sync status: nothing running yet for this album.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Not synced yet" } },
        "de": { "stringUnit": { "state": "translated", "value": "Noch nicht synchronisiert" } }
      }
    },
    "albumsync.phase_scanning": {
      "extractionState": "manual",
      "comment": "Album sync status: reading the local album contents (no upload yet).",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Preparing album" } },
        "de": { "stringUnit": { "state": "translated", "value": "Album wird vorbereitet" } }
      }
    },
    "albumsync.phase_backing_up": {
      "extractionState": "manual",
      "comment": "Album sync status: photos missing from the Proton library are being backed up (checking/hashing included - wording must stay honest, most work is often verification).",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Backing up missing photos" } },
        "de": { "stringUnit": { "state": "translated", "value": "Fehlende Fotos werden gesichert" } }
      }
    },
    "albumsync.phase_checking": {
      "extractionState": "manual",
      "comment": "Album sync status: comparing against the photos already in the Proton album - nothing is uploading.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Checking existing photos" } },
        "de": { "stringUnit": { "state": "translated", "value": "Bestehende Fotos werden geprüft" } }
      }
    },
    "albumsync.phase_attaching": {
      "extractionState": "manual",
      "comment": "Album sync status: already-uploaded photos are being added to the Proton album (membership only, no media re-upload).",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Adding photos to album" } },
        "de": { "stringUnit": { "state": "translated", "value": "Fotos werden zum Album hinzugefügt" } }
      }
    },
    "albumsync.phase_completed": {
      "extractionState": "manual",
      "comment": "Album sync status: the run finished with every attachable photo in the album.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Album synced" } },
        "de": { "stringUnit": { "state": "translated", "value": "Album synchronisiert" } }
      }
    },
    "albumsync.phase_needs_attention": {
      "extractionState": "manual",
      "comment": "Album sync status: the run finished but some photos could not be backed up or added.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Needs attention" } },
        "de": { "stringUnit": { "state": "translated", "value": "Benötigt Aufmerksamkeit" } }
      }
    },
    "albumsync.detail_backed_up %lld %lld": {
      "extractionState": "manual",
      "comment": "Album sync backup progress: %1$lld of %2$lld album photos are safe in the Proton library.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "%1$lld of %2$lld backed up" } },
        "de": { "stringUnit": { "state": "translated", "value": "%1$lld von %2$lld gesichert" } }
      }
    },
    "albumsync.detail_attached %lld %lld": {
      "extractionState": "manual",
      "comment": "Album sync attach progress: %1$lld of %2$lld photos are in the Proton album.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "%1$lld of %2$lld added to album" } },
        "de": { "stringUnit": { "state": "translated", "value": "%1$lld von %2$lld zum Album hinzugefügt" } }
      }
    },
    "albumsync.detail_completed %lld": {
      "extractionState": "manual",
      "comment": "Album sync completed detail: how many of this album's photos are in the Proton album.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "%lld photos in the album" } },
        "de": { "stringUnit": { "state": "translated", "value": "%lld Fotos im Album" } }
      }
    },
    "albumsync.detail_needs_attention %lld": {
      "extractionState": "manual",
      "comment": "Album sync attention detail: photos that could not be backed up or added to the album.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "%lld photos need attention" } },
        "de": { "stringUnit": { "state": "translated", "value": "%lld Fotos benötigen Aufmerksamkeit" } }
      }
    },
    "albumsync.error_name_conflict": {
      "extractionState": "manual",
      "comment": "Album sync error: a Proton album with the same name already exists and the user has not decided yet whether to use it.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A Proton album with this name already exists. Choose whether to use it or cancel."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Proton-Album mit diesem Namen existiert bereits. Wähle, ob es verwendet werden soll, oder brich ab."
          }
        }
      }
    },
    "albumsync.error_store_unavailable": {
      "extractionState": "manual",
      "comment": "Album sync error: the local album-mapping database could not be opened; syncing without it could create duplicate albums.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Album sync is unavailable because its local database could not be opened."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Album-Synchronisierung ist nicht verfügbar, weil die lokale Datenbank nicht geöffnet werden konnte."
          }
        }
      }
    },
    "albumsync.error_already_running": {
      "extractionState": "manual",
      "comment": "Album sync error: only one album syncs at a time in v1.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Another album is already syncing. Try again when it finishes."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein anderes Album wird bereits synchronisiert. Versuche es danach erneut."
          }
        }
      }
    },
    "albumsync.error_stopped": {
      "extractionState": "manual",
      "comment": "Album sync status after the user stops a run: everything done so far is durable; re-running converges.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sync stopped. Progress is saved and the next run continues where it left off."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Synchronisierung gestoppt. Der Fortschritt bleibt erhalten, der nächste Lauf setzt fort."
          }
        }
      }
    },
    "albumsync.state_not_synced": {
      "extractionState": "manual",
      "comment": "Selected-album row state: chosen for sync but no run has completed yet.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Not synced yet" } },
        "de": { "stringUnit": { "state": "translated", "value": "Noch nicht synchronisiert" } }
      }
    },
    "albumsync.state_synced %@": {
      "extractionState": "manual",
      "comment": "Selected-album row state. %@ is a relative time like 'yesterday' / 'gestern'.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Synced %@" } },
        "de": { "stringUnit": { "state": "translated", "value": "Synchronisiert %@" } }
      }
    },
    "albumsync.state_missing": {
      "extractionState": "manual",
      "comment": "Selected-album row state: the album no longer exists in the local photo library.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "No longer in the photo library" } },
        "de": { "stringUnit": { "state": "translated", "value": "Nicht mehr in der Foto-Mediathek" } }
      }
    },
    "albumsync.state_needs_decision": {
      "extractionState": "manual",
      "comment": "Selected-album row state: a same-name Proton album exists and the user has not decided yet.",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Waiting for your decision" } },
        "de": { "stringUnit": { "state": "translated", "value": "Wartet auf deine Entscheidung" } }
      }
    },
    "brand.product_name": {
      "extractionState": "manual",
      "comment": "Visible product name. Keep as a single key so rebranding is one catalog edit plus bundle metadata.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Proton Photos"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Proton Photos"
          }
        }
      }
    },
    "action.cancel": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancel"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Abbrechen"
          }
        }
      }
    },
    "action.retry": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Retry"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erneut versuchen"
          }
        }
      }
    },
    "tag.favorites": {
      "extractionState": "manual",
      "comment": "Smart-filter tag.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Favorites"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Favoriten"
          }
        }
      }
    },
    "tag.screenshots": {
      "extractionState": "manual",
      "comment": "Smart-filter tag.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Screenshots"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bildschirmfotos"
          }
        }
      }
    },
    "tag.videos": {
      "extractionState": "manual",
      "comment": "Smart-filter tag.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Videos"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Videos"
          }
        }
      }
    },
    "tag.live_photos": {
      "extractionState": "manual",
      "comment": "Smart-filter tag (Apple term, unchanged in German).",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Live Photos"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Live Photos"
          }
        }
      }
    },
    "tag.motion": {
      "extractionState": "manual",
      "comment": "Smart-filter tag (kept in both languages).",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Motion"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Motion"
          }
        }
      }
    },
    "tag.selfies": {
      "extractionState": "manual",
      "comment": "Smart-filter tag.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Selfies"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Selfies"
          }
        }
      }
    },
    "tag.portraits": {
      "extractionState": "manual",
      "comment": "Smart-filter tag.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Portraits"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Porträts"
          }
        }
      }
    },
    "tag.bursts": {
      "extractionState": "manual",
      "comment": "Smart-filter tag (Apple Photos uses “Serien”).",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bursts"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Serien"
          }
        }
      }
    },
    "tag.panoramas": {
      "extractionState": "manual",
      "comment": "Smart-filter tag.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Panoramas"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Panoramen"
          }
        }
      }
    },
    "tag.raw": {
      "extractionState": "manual",
      "comment": "Smart-filter tag (technical term).",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "RAW"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "RAW"
          }
        }
      }
    },
    "error.video.not_a_video": {
      "extractionState": "manual",
      "comment": "Shown when an item isn’t actually a video.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is not a video."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies ist kein Video."
          }
        }
      }
    },
    "error.video.metadata_unavailable": {
      "extractionState": "manual",
      "comment": "Video metadata could not be resolved.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Video information could not be loaded."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Video-Informationen konnten nicht geladen werden."
          }
        }
      }
    },
    "error.video.unsupported_codec": {
      "extractionState": "manual",
      "comment": "AVFoundation can’t decode the codec.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This video format isn’t supported."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Videoformat wird nicht unterstützt."
          }
        }
      }
    },
    "error.video.stream_unavailable": {
      "extractionState": "manual",
      "comment": "Backend exposes no stream URL.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No stream is available for this video."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Für dieses Video ist kein Stream verfügbar."
          }
        }
      }
    },
    "error.video.range_not_supported": {
      "extractionState": "manual",
      "comment": "Backend can’t serve byte ranges.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This video can’t be streamed."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Video kann nicht gestreamt werden."
          }
        }
      }
    },
    "error.video.decryption_failed": {
      "extractionState": "manual",
      "comment": "A block failed to decrypt.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The video couldn’t be decrypted."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Video konnte nicht entschlüsselt werden."
          }
        }
      }
    },
    "error.video.network_unavailable": {
      "extractionState": "manual",
      "comment": "Network/transport error.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No network connection."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine Netzwerkverbindung."
          }
        }
      }
    },
    "error.video.auth_expired": {
      "extractionState": "manual",
      "comment": "Auth token expired.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your session has expired. Please sign in again."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Sitzung ist abgelaufen. Bitte erneut anmelden."
          }
        }
      }
    },
    "error.video.quota_rate_limited": {
      "extractionState": "manual",
      "comment": "Server returned 429 / quota.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Too many requests. Please try again later."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zu viele Anfragen. Bitte später erneut versuchen."
          }
        }
      }
    },
    "error.video.local_file_error": {
      "extractionState": "manual",
      "comment": "Local cache/temp file error.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The video file couldn’t be read."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Videodatei konnte nicht gelesen werden."
          }
        }
      }
    },
    "error.video.player_item_failed": {
      "extractionState": "manual",
      "comment": "Generic AVPlayerItem failure.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The video couldn’t be played."
          }
        },
        "de": {
          "stringUnit": {
